	keywords = {Female, Humans, Biomarkers, Phenotype, Genome-Wide Association Study, Polymorphism, Single Nucleotide, Hypertension, Cohort Studies, Pregnancy, Acetone, Cholestasis, Intrahepatic, Lipoproteins, Magnetic Resonance Spectroscopy, Mendelian Randomization Analysis, Metabolic Networks and Pathways, Metabolomics, Pregnancy Complications},
	pages = {130--138},
