	pmid = {15632069},
	pmcid = {PMC543431},
	pages = {685--698},
	file = {Full Text:/Users/cyakaboski/Zotero/storage/4LFUT2LN/Steele-Perkins et al. - 2005 - The Transcription Factor Gene Nfib Is Essential fo.pdf:application/pdf},
}

