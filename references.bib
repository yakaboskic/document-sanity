	pmid = {31078624},
	keywords = {Humans, Male, Animals, Mice, Knockout, Signal Transduction, Acta2, Alanine Aminotransferase, Antibodies, Neutralizing, Cell Death, Collagen, Fatty Liver, Fibroblasts, Hepatic Stellate Cells, Hepatitis, Hepatocytes, Inflammation Mediators, Interleukin-11, Interleukin-11 Receptor alpha Subunit, Liver, Liver Cirrhosis, Experimental, Mice, Inbred C57BL, Non-alcoholic Fatty Liver Disease, THP-1 Cells},
	pages = {777--792.e14},
	file = {Submitted Version:/Users/cyakaboski/Zotero/storage/EYGLQRN8/Widjaja et al. - 2019 - Inhibiting Interleukin 11 Signaling Reduces Hepato.pdf:application/pdf},
}

@article{seok_genomic_2013,
	title = {Genomic responses in mouse models poorly mimic human inflammatory diseases},
	volume = {110},
	issn = {1091-6490},
	doi = {10.1073/pnas.1222878110},
	abstract = {A cornerstone of modern biomedical research is the use of mouse models to explore basic pathophysiological mechanisms, evaluate new therapeutic approaches, and make go or no-go decisions to carry new drug candidates forward into clinical trials. Systematic studies evaluating how well murine models mimic human inflammatory diseases are nonexistent. Here, we show that, although acute inflammatory stresses from different etiologies result in highly similar genomic responses in humans, the responses in corresponding mouse models correlate poorly with the human conditions and also, one another. Among genes changed significantly in humans, the murine orthologs are close to random in matching their human counterparts (e.g., R(2) between 0.0 and 0.1). In addition to improvements in the current animal model systems, our study supports higher priority for translational medical research to focus on the more complex human conditions rather than relying on mouse models to study human inflammatory diseases.},
	language = {eng},
	number = {9},
	journal = {Proceedings of the National Academy of Sciences of the United States of America},
	author = {Seok, Junhee and Warren, H. Shaw and Cuenca, Alex G. and Mindrinos, Michael N. and Baker, Henry V. and Xu, Weihong and Richards, Daniel R. and McDonald-Smith, Grace P. and Gao, Hong and Hennessy, Laura and Finnerty, Celeste C. and López, Cecilia M. and Honari, Shari and Moore, Ernest E. and Minei, Joseph P. and Cuschieri, Joseph and Bankey, Paul E. and Johnson, Jeffrey L. and Sperry, Jason and Nathens, Avery B. and Billiar, Timothy R. and West, Michael A. and Jeschke, Marc G. and Klein, Matthew B. and Gamelli, Richard L. and Gibran, Nicole S. and Brownstein, Bernard H. and Miller-Graziano, Carol and Calvano, Steve E. and Mason, Philip H. and Cobb, J. Perren and Rahme, Laurence G. and Lowry, Stephen F. and Maier, Ronald V. and Moldawer, Lyle L. and Herndon, David N. and Davis, Ronald W. and Xiao, Wenzhong and Tompkins, Ronald G. and {Inflammation and Host Response to Injury, Large Scale Collaborative Research Program}},
	month = feb,
	year = {2013},
	pmid = {23401516},
	pmcid = {PMC3587220},
	keywords = {Female, Humans, Male, Animals, Mice, Gene Expression Regulation, Genomics, Time Factors, Inflammation, Signal Transduction, Mice, Inbred C57BL, Acute Disease, Adolescent, Adult, Burns, Disease Models, Animal, Endotoxemia, Wounds and Injuries, Young Adult},
	pages = {3507--3512},
	file = {Full Text:/Users/cyakaboski/Zotero/storage/TTH26JMX/Seok et al. - 2013 - Genomic responses in mouse models poorly mimic hum.pdf:application/pdf},
}

