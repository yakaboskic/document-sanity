	pages = {698--706},
	file = {Full Text:/Users/cyakaboski/Zotero/storage/7MYJ4F8X/Hernandez-Ochoa et al. - 2010 - The Ability of the Aryl Hydrocarbon Receptor to Re.pdf:application/pdf},
