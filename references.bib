	author = {Wu, Patrick and Feng, QiPing and Kerchberger, Vern Eric and Nelson, Scott D. and Chen, Qingxia and Li, Bingshan and Edwards, Todd L. and Cox, Nancy J. and Phillips, Elizabeth J. and Stein, C. Michael and Roden, Dan M. and Denny, Joshua C. and Wei, Wei-Qi},
