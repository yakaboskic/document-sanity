	pmid = {24088041},
	pmcid = {PMC4211433},
	keywords = {Humans, Mutation, Sequence Analysis, DNA, Phenotype, Exome, Child, Genetic Testing, Adolescent, Young Adult, Child, Preschool, Genes, Dominant, Genes, Recessive, Genes, X-Linked, Genetic Diseases, Inborn},
