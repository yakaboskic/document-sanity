@article{lescroart_defining_2018,
	title = {Defining the earliest step of cardiovascular lineage segregation by single-cell {RNA}-seq},
	volume = {359},
	url = {https://www.science.org/doi/10.1126/science.aao4174},
	doi = {10.1126/science.aao4174},
	abstract = {Mouse heart development arises from Mesp1-expressing cardiovascular progenitors (CPs) that are specified during gastrulation. The molecular processes that control early regional and lineage segregation of CPs have been unclear. We performed single-cell RNA sequencing of wild-type and Mesp1-null CPs in mice. We showed that populations of Mesp1 CPs are molecularly distinct and span the continuum between epiblast and later mesodermal cells, including hematopoietic progenitors. Single-cell transcriptome analysis of Mesp1-deficient CPs showed that Mesp1 is required for the exit from the pluripotent state and the induction of the cardiovascular gene expression program. We identified distinct populations of Mesp1 CPs that correspond to progenitors committed to different cell lineages and regions of the heart, identifying the molecular features associated with early lineage restriction and regional segregation of the heart at the early stage of mouse gastrulation.},
	number = {6380},
	urldate = {2025-09-03},
	journal = {Science},
	author = {Lescroart, Fabienne and Wang, Xiaonan and Lin, Xionghui and Swedlund, Benjamin and Gargouri, Souhir and Sànchez-Dànes, Adriana and Moignard, Victoria and Dubois, Christine and Paulissen, Catherine and Kinston, Sarah and Göttgens, Berthold and Blanpain, Cédric},
	month = mar,
	year = {2018},
	note = {Publisher: American Association for the Advancement of Science},
	pages = {1177--1181},
	file = {Full Text PDF:/Users/cyakaboski/Zotero/storage/PE58WPNC/Lescroart et al. - 2018 - Defining the earliest step of cardiovascular linea.pdf:application/pdf},
}

