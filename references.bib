	keywords = {Genome, Human, Humans, Drug Discovery, Drug Repositioning, Phenotype, Genome-Wide Association Study, Polymorphism, Single Nucleotide, Molecular Targeted Therapy, Reproducibility of Results, Linkage Disequilibrium, Genetic Loci, Translational Research, Biomedical},
	pages = {eaag1166},
	file = {Full Text:/Users/cyakaboski/Zotero/storage/K4PTRZXI/Finan et al. - 2017 - The druggable genome and support for target identi.pdf:application/pdf},
}

@article{costanzo_realizing_2025,
	title = {Realizing the promise of genome-wide association studies for effector gene prediction},
	volume = {57},
	issn = {1546-1718},
	doi = {10.1038/s41588-025-02210-5},
	abstract = {Genome-wide association studies (GWAS) identify regions of the genome in which genetic variation is associated with the risk of complex diseases, such as diabetes, or the magnitude of traits, such as blood pressure. Determining which 'effector genes' mediate the effects of GWAS associations is essential to using GWAS to understand disease mechanisms and develop new therapies. In recent years, GWAS authors have increasingly included effector gene predictions as part of their study results. However, the research community has not yet converged on standards for generating or reporting these predictions. In this Perspective, we illustrate the diversity of the evidence types used to support effector gene predictions and argue for future initiatives to increase their accessibility and usefulness.},
